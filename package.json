{
  "name": "markreader",
  "version": "1.0.0",
  "description": "Markdown reader and docs viewer",
  "author": "Sandro Lain",
  "main": "dist/index.html",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:watch": "vite --host 0.0.0.0 --port 4173"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandrolain/markreader.git"
  },
  "keywords": [
    "markdown",
    "wiki"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/marked": "^6.0.0",
    "@types/node": "^26.1.0",
    "@types/node-emoji": "^2.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "buffer": "^6.0.3",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@types/axios": "^0.14.4",
    "@types/highlightjs": "^10.1.0",
    "axios": "^1.18.1",
    "emojilib": "^4.0.3",
    "front-matter": "^4.0.2",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "marked-alert": "^2.1.2",
    "marked-emoji": "^2.0.3",
    "marked-footnote": "^1.4.0",
    "marked-gfm-heading-id": "^4.1.4",
    "marked-highlight": "^2.2.4",
    "marked-katex-extension": "^5.1.10",
    "mermaid": "^11.16.0",
    "node-emoji": "^2.2.0",
    "sweet-scroll": "^4.0.0",
    "yaml": "^2.9.0"
  }
